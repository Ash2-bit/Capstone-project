# ==========================
# AI MODELS (Mencegah file besar terupload)
# ==========================
# GitHub menolak file di atas 100MB. Aktifkan baris di bawah 
# jika folder models berisi file AI yang besar.
sapulidi-ai/models/*.pt
sapulidi-ai/models/*.bin
sapulidi-ai/models/*.h5
sapulidi-ai/models/*.onnx

